{
  "name": "laraskills",
  "version": "1.0.0-beta.15",
  "description": "AI-ready Laravel 13 skills, rules, agents, deterministic retrieval CLI, and MCP server",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "laravel",
    "laravel13",
    "laraskills",
    "php",
    "pest",
    "tdd",
    "eloquent",
    "opencode",
    "claude-code",
    "cursor",
    "gemini-cli",
    "codex-cli",
    "copilot",
    "ai-agents",
    "skills",
    "rules",
    "hooks",
    "mcp",
    "retrieval",
    "cli",
    "knowledge"
  ],
  "author": {
    "name": "LaraSkills Contributors"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elmochilyas/laraskills.git"
  },
  "bugs": {
    "url": "https://github.com/elmochilyas/laraskills/issues"
  },
  "homepage": "https://github.com/elmochilyas/laraskills#readme",
  "bin": {
    "laraskills": "scripts/laraskills.mjs",
    "laraskills-mcp": "scripts/laraskills-mcp.mjs",
    "laravel-ecc": "scripts/laraskills.mjs",
    "laravel-ecc-mcp": "scripts/laraskills-mcp.mjs"
  },
  "files": [
    "skills/",
    "rules/",
    "agents/",
    "commands/",
    "hooks/",
    "mcp-configs/",
    ".opencode/",
    ".claude/",
    ".cursor/",
    ".gemini/",
    ".codex/",
    ".vscode/",
    ".zed/",
    ".trae/",
    ".qwen/",
    ".codebuddy/",
    ".kiro/",
    ".github/copilot-instructions.md",
    "src/",
    "scripts/laraskills.mjs",
    "scripts/laraskills-mcp.mjs",
    "scripts/mcp/",
    "install.ps1",
    "install.sh",
    "update.ps1",
    "update.sh",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    "CLAUDE.md",
    "VERSION"
  ],
  "scripts": {
    "postinstall": "node -e \"console.log('\\n  laraskills installed.\\n  Project setup: npx laraskills install --profile core\\n  Retrieval setup: npx laraskills setup --laraskills-root <path>\\n  Diagnostics: npx laraskills doctor\\n  MCP server: npx laraskills-mcp\\n')\"",
    "test": "node --test",
    "benchmark": "node tests/retrieval/run-benchmarks.mjs",
    "benchmark:performance": "node tests/retrieval/run-performance-benchmarks.mjs",
    "mcp:start": "node scripts/laraskills-mcp.mjs",
    "verify:clean-clone": "node scripts/verify-clean-clone.mjs",
    "verify:packed-install": "node scripts/verify-packed-install.mjs",
    "verify:mcp": "node scripts/verify-mcp-smoke.mjs",
    "test:cache-smoke": "node --test tests/phase-15/cache-smoke.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  }
}
