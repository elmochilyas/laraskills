{
  "name": "laravel-ecc",
  "version": "1.0.0-beta.14",
  "description": "Laravel 13 ECC — AI-ready Laravel skills, rules, agents, and CLI harness configs for OpenCode, Claude Code, Cursor, Gemini, Codex, Copilot, and more",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "laravel",
    "laravel13",
    "ecc",
    "php",
    "pest",
    "tdd",
    "eloquent",
    "opencode",
    "claude-code",
    "cursor",
    "gemini-cli",
    "codex-cli",
    "copilot",
    "ai-agents",
    "skills",
    "rules",
    "hooks",
    "mcp",
    "retrieval",
    "cli",
    "knowledge"
  ],
  "author": {
    "name": "Laravel ECC Contributors"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elmochilyas/laravel-ecc.git"
  },
  "bugs": {
    "url": "https://github.com/elmochilyas/laravel-ecc/issues"
  },
  "homepage": "https://github.com/elmochilyas/laravel-ecc#readme",
  "bin": {
    "laravel-ecc": "scripts/laravel-ecc.mjs",
    "laravel-ecc-mcp": "scripts/laravel-ecc-mcp.mjs"
  },
  "files": [
    "skills/",
    "rules/",
    "agents/",
    "commands/",
    "hooks/",
    "mcp-configs/",
    ".opencode/",
    ".claude/",
    ".cursor/",
    ".gemini/",
    ".codex/",
    ".vscode/",
    ".zed/",
    ".trae/",
    ".qwen/",
    ".codebuddy/",
    ".kiro/",
    ".github/",
    "src/",
    "scripts/laravel-ecc.mjs",
    "scripts/laravel-ecc-mcp.mjs",
    "scripts/mcp/",
    "install.ps1",
    "install.sh",
    "update.ps1",
    "update.sh",
    "AGENTS.md",
    "CLAUDE.md",
    "VERSION"
  ],
  "scripts": {
    "postinstall": "node -e \"console.log('\\n  laravel-ecc installed! Run `npx laravel-ecc setup` to configure ECC root.\\n  Retrieval commands: npx laravel-ecc retrieve/search/get/prerequisites/related/validate\\n  Diagnostics: npx laravel-ecc doctor\\n  MCP server: npx laravel-ecc-mcp\\n')\"",
    "test": "node --test tests/retrieval/*.test.mjs",
    "benchmark": "node tests/retrieval/run-benchmarks.mjs",
    "benchmark:performance": "node tests/retrieval/run-performance-benchmarks.mjs",
    "mcp:start": "node scripts/laravel-ecc-mcp.mjs",
    "verify:clean-clone": "node scripts/verify-clean-clone.mjs",
    "verify:packed-install": "node scripts/verify-packed-install.mjs",
    "verify:mcp": "node scripts/verify-mcp-smoke.mjs",
    "test:cache-smoke": "node --test tests/phase-15/cache-smoke.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  }
}
