{
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md",
    ".laraskills/skills/laravel-patterns/SKILL.md",
    ".laraskills/skills/laravel-tdd/SKILL.md",
    ".laraskills/skills/laravel-security/SKILL.md",
    "rules/common/coding-style.md",
    "rules/common/testing.md",
    "rules/common/security.md",
    "rules/php/coding-style.md",
    "rules/php/patterns.md",
    "rules/php/testing.md",
    "rules/php/security.md",
    "rules/php/hooks.md",
    "rules/laravel/coding-style.md",
    "rules/laravel/patterns.md",
    "rules/laravel/testing.md",
    "rules/laravel/security.md",
    "rules/laravel/hooks.md",
    "rules/laravel/service-container.md",
    "rules/laravel/service-providers.md",
    "rules/laravel/facades.md",
    "rules/laravel/contracts.md",
    "rules/laravel/middleware.md",
    "rules/laravel/architecture.md",
    ".laraskills/skills/laravel-core-internals/SKILL.md",
    ".laraskills/skills/laravel-eloquent/SKILL.md",
    ".laraskills/skills/laravel-database/SKILL.md",
    "rules/laravel/eloquent.md",
    "rules/laravel/database.md"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "matcher-patterns": ["**/*.php"],
        "command": "./vendor/bin/pint \"$FILE_PATH\"",
        "description": "Auto-format edited PHP files with Laravel Pint"
      },
      {
        "matcher": "Write|Edit",
        "matcher-patterns": ["**/*.php"],
        "command": "./vendor/bin/phpstan analyse \"$FILE_PATH\" --level=6 --no-progress",
        "description": "Run PHPStan on edited PHP files"
      }
    ]
  }
}
