{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "laravel-ecc": {
      "type": "local",
      "command": [
        "node",
        "C:\\path\\to\\laravel-ecc\\scripts\\laravel-ecc-mcp.mjs"
      ],
      "enabled": true,
      "timeout": 10000,
      "environment": {
        "ECC_ROOT": "C:\\path\\to\\laravel-ecc"
      }
    }
  }
}
