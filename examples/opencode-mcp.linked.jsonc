{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "laraskills": {
      "type": "local",
      "command": [
        "laraskills-mcp"
      ],
      "enabled": true,
      "timeout": 10000,
      "environment": {
        "LARASKILLS_ROOT": "C:\\path\\to\\laraskills"
      }
    }
  }
}
